DATABASE_URL="postgresql://postgres:postgres@localhost:5432/internal_tool?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
CORS_ORIGIN="http://localhost:3000"

SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
MAIL_FROM="CRM Reminders <no-reply@example.com>"
INTERNAL_REMINDER_EMAIL="team@example.com"
BIRTHDAY_CRON_ENABLED="true"
BIRTHDAY_CRON_EXPRESSION="0 8 * * *"

ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-now"
ADMIN_NAME="System Admin"
