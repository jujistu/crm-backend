{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "resolvePackageJsonExports": false,
    "esModuleInterop": true,
    "outDir": "./dist/prisma",
    "baseUrl": "./",
    "paths": {
      "@prisma/client": ["./node_modules/.prisma/client/index.d.ts"]
    }
  },
  "include": ["prisma/**/*.ts"]
}
